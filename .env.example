# Environment Variables

# Public site URL for SEO, sitemap, and Open Graph
NEXT_PUBLIC_SITE_URL=https://ayoadeyi.vercel.app

# EmailJS (contact form - set in Vercel dashboard)
# Create a template at https://www.emailjs.com with params:
# from_name, from_email, service, message, reply_to
EMAILJS_SERVICE_ID=
EMAILJS_TEMPLATE_ID=
EMAILJS_PUBLIC_KEY=
# Optional: private key for stricter EmailJS API access
EMAILJS_PRIVATE_KEY=

# Environment Variables

# Public site URL for SEO, sitemap, and Open Graph
NEXT_PUBLIC_SITE_URL=https://ayoadeyi.vercel.app

# EmailJS contact form (Vercel → Settings → Environment Variables → Production)
# IMPORTANT: use these exact names, then Redeploy after saving.
# Template params: from_name, from_email, service, message, reply_to
EMAILJS_SERVICE_ID=
EMAILJS_TEMPLATE_ID=
EMAILJS_PUBLIC_KEY=
EMAILJS_PRIVATE_KEY=

# Legacy names also supported if you already set these:
# NEXT_PUBLIC_EMAILJS_SERVICE_ID=
# NEXT_PUBLIC_EMAILJS_TEMPLATE_ID=
# NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=
